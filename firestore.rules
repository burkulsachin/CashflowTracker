rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Returns true if the user's UID matches the provided userId.
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Rules for user-specific data
    match /users/{userId} {
      // A user can create, read, update, or delete their own user document.
      allow read, update, delete: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.id == userId;
      
      // A user can read and write to any document in any of their subcollections.
      // This single rule covers list, get, create, update, and delete for all
      // nested data like transactions, budgets, and goals.
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}